{
  "name": "@heirshq/design-system",
  "version": "1.9.0",
  "description": "Heirs Design System - A reusable component library",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles": "./dist/styles.css",
    "./theme": "./dist/theme.css"
  },
  "bin": {
    "create-mfe": "./scaffold-mfe.mjs"
  },
  "files": [
    "dist",
    "scaffold-mfe.mjs"
  ],
  "scripts": {
    "build": "tsc && node --input-type=module --eval \"import{copyFileSync}from'node:fs';copyFileSync('src/styles.css','dist/styles.css');copyFileSync('src/theme.css','dist/theme.css')\"",
    "build:registry": "tsx scripts/build-registry.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./src",
    "prettier:write-all": "prettier --write .",
    "prettier:write": "prettier --write \"./src/**/*.{js,jsx,ts,tsx}\"",
    "prettier:check": "prettier --check \"./src/**/*.{js,jsx,ts,tsx}\"",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "react",
    "components",
    "design-system",
    "ui"
  ],
  "license": "UNLICENSED",
  "author": "Heirs Technologies",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HeirsHQ/design-system.git"
  },
  "peerDependencies": {
    "@base-ui/react": ">=1.0.0",
    "@tanstack/react-table": ">=8.0.0",
    "cmdk": ">=1.0.0",
    "lucide-react": ">=1.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-hook-form": ">=7.0.0",
    "recharts": ">=3.0.0",
    "sonner": ">=2.0.0",
    "tailwindcss": ">=4.0.0",
    "tailwindcss-animate": ">=1.0.7",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@base-ui/react": {
      "optional": true
    },
    "@tanstack/react-table": {
      "optional": true
    },
    "cmdk": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "recharts": {
      "optional": true
    },
    "sonner": {
      "optional": true
    },
    "tailwindcss-animate": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@tanstack/react-table": "^8.21.3",
    "@eslint/js": "^9.18.0",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-onboarding": "^10.2.17",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.10",
    "@types/react-color": "^3.0.13",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "cmdk": "^1.1.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^10.2.17",
    "globals": "^15.14.0",
    "playwright": "^1.58.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "lucide-react": "^1.17.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "storybook": "^10.2.17",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^4.0.18",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "react-color": "^2.19.3",
    "react-to-print": "^3.2.0",
    "tailwind-merge": "^3.4.0"
  }
}
